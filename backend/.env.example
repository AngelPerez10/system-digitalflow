# Backend environment variables.
# Copy this file to backend/.env in local dev. In Render, set these in the
# service Environment dashboard.

# --- Django ---
SECRET_KEY=
ALLOWED_HOSTS=localhost,127.0.0.1
DEBUG=true

# --- Database (Render auto-injects DATABASE_URL on managed Postgres) ---
DATABASE_URL=

# --- PDF generation (cotizaciones, ordenes) -----------------------------------
# Opcional: API externa https://htmldocs.com/ (si falla, se usa motor local).
# Nombre legacy aceptado: HTMLEDOCS_API_KEY
HTMLDOCS_API_KEY=

# Motor local: Playwright + Chromium (requirements.txt + build.sh en Render).
# LOCAL (PowerShell, carpeta backend, venv activado) — orden obligatorio:
#   1) pip install -r requirements.txt
#   2) python -m playwright install chromium
# Si ejecutas el paso 2 antes del 1, sale "No module named playwright".
# Para forzar solo htmldocs sin Chromium: DISABLE_LOCAL_PDF=1
DISABLE_LOCAL_PDF=

# --- Cloudinary (uploads) ---
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
