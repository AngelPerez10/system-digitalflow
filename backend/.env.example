# Backend environment variables.
# Copy this file to backend/.env in local dev. In Render, set these in the
# service Environment dashboard.

# --- Django ---
SECRET_KEY=
ALLOWED_HOSTS=localhost,127.0.0.1
DEBUG=true

# --- Database (Render auto-injects DATABASE_URL on managed Postgres) ---
DATABASE_URL=

# --- PDF generation (cotizaciones, ordenes) -----------------------------------
# Opcional: API externa https://htmldocs.com/ (si falla, se usa motor local).
# Nombre legacy aceptado: HTMLEDOCS_API_KEY
HTMLDOCS_API_KEY=

# Motor local: Playwright + Chromium (requirements.txt + build.sh en Render).
# Los binarios se guardan en backend/.playwright-browsers (PLAYWRIGHT_BROWSERS_PATH
# en build.sh). Opcional: PLAYWRIGHT_BROWSERS_PATH=/ruta/absoluta para otro disco.
# build.sh solo ejecuta apt/playwright install-deps si apt-get update funciona;
# en builders con fs de solo lectura (p. ej. algunos entornos Render) se omite y
# el build sigue con `playwright install chromium`.
# LOCAL (PowerShell, carpeta backend, venv activado) — orden obligatorio:
#   1) pip install -r requirements.txt
#   2) python -m playwright install chromium
# Si ejecutas el paso 2 antes del 1, sale "No module named playwright".
# Para forzar solo htmldocs sin Chromium: DISABLE_LOCAL_PDF=1
DISABLE_LOCAL_PDF=

# Timeout HTTP a htmldocs (segundos). Si no se define y hay Playwright, default ~12s.
# HTMLDOCS_TIMEOUT=12

# Render / Gunicorn: PDF puede tardar >30s (htmldocs + Playwright). Sin esto, 502 del proxy.
# Start Command ejemplo:
#   gunicorn config.wsgi:application --bind 0.0.0.0:$PORT --timeout 120
# O: GUNICORN_CMD_ARGS=--timeout 120

# --- SYSCOM (catálogo mayorista en Productos / Cotizaciones) ---
# Obligatorio en producción si usas catálogo SYSCOM; sin esto el API responde 502.
SYSCOM_CLIENT_ID=
SYSCOM_CLIENT_SECRET=
# SYSCOM_API_BASE=https://developers.syscom.mx/api/v1
# SYSCOM_OAUTH_URL=https://developers.syscom.mx/oauth/token

# --- TVC (catálogo mayorista tvc.mx en Productos / Cotizaciones) ---
# Token JWT Bearer generado en Mi Perfil → API Clientes (vigencia ~1 año).
TVC_API_TOKEN=
# TVC_API_BASE=https://api.tvc.mx
# TVC_MEDIA_BASE=https://cdn.tvc.mx

# --- Cloudinary (uploads) ---
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# --- Wialon (Antarix GPS / cuentas en Operación) ---
WIALON_ACCESS_TOKEN=
# WIALON_API_BASE=https://hst-api.wialon.com/wialon/ajax.html
# Caché en memoria (segundos): sesión, listado usuarios, índice de unidades
# WIALON_SESSION_TTL_SEC=300
# WIALON_USERS_CACHE_TTL_SEC=90
# WIALON_UNITS_INDEX_TTL_SEC=300

# --- CORS / CSRF (Render: front y back en dominios distintos) ---
# En producción se fusionan con los orígenes Render por defecto; añade aquí dominios extra.
# CORS_ALLOWED_ORIGINS=https://sistema-grupo-atr.onrender.com
# CSRF_TRUSTED_ORIGINS=https://sistema-grupo-atr.onrender.com

# --- SICAR (MySQL externo — Facturas CFDI en Ventas) ---
# Render NO alcanza 192.168.x sin túnel VPN. Si MySQL tarda, el navegador puede mostrar
# error CORS aunque la causa sea timeout de red (fail-fast en producción evita eso).
SICAR_DB_HOST=
SICAR_DB_PORT=3307
SICAR_DB_USER=
SICAR_DB_PASSWORD=
SICAR_DB_NAME=sicar
