# Backend environment variables.
# Copy this file to backend/.env in local dev. In Render, set these in the
# service Environment dashboard.

# --- Django ---
SECRET_KEY=
ALLOWED_HOSTS=localhost,127.0.0.1
DEBUG=true

# --- Database (Render auto-injects DATABASE_URL on managed Postgres) ---
DATABASE_URL=

# --- PDF generation (cotizaciones, ordenes) -----------------------------------
# Primary provider. Get an API key at https://htmldocs.com/.
# (Note: legacy code used the typo'd name HTMLEDOCS_API_KEY; the helper at
# backend/apps/cotizaciones/pdf_render.py still accepts that name as a
# fallback during the rename window.)
HTMLDOCS_API_KEY=

# Free fallback provider used when htmldocs returns 5xx or is unreachable.
# Get a key at https://app.pdfshift.io/ (free tier: 50 conversions/month, no
# watermark on authenticated requests). Documents from the fallback are
# only generated when the primary fails, so the free tier is enough for a
# safety net.
PDFSHIFT_API_KEY=sk_93233f1b176268f8ef8ae29dcd7d9872a21f370f

# --- Cloudinary (uploads) ---
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
